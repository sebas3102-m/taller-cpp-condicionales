#include <iostream>
#include <string>

int main() {
    int nota;
    std::cout << "Ingresa la nota (0-100): ";
    std::cin >> nota;

    if (nota < 0 || nota > 100) {
        std::cout << "Nota invalida.\n";
        return 0;
    }

    std::string letra;
    std::string estado;

    // Letra con operadores relacionales
    if (nota >= 90) {
        letra = "A";
    } else if (nota >= 80) {
        letra = "B";
    } else if (nota >= 70) {
        letra = "C";
    } else if (nota >= 60) {
        letra = "D";
    } else {
        letra = "F";
    }

    // Estado
    estado = (nota >= 60) ? "Aprobado" : "Reprobado";

    std::cout << "Calificacion: " << letra << " - " << estado << "\n";
    return 0;
}
